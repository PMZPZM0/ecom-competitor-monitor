PORT=4317
VITE_API_BASE=http://localhost:4317

# Optional channel keys for AI image generation and analysis. Values saved in the UI take priority.
MODEL_STABLE_API_KEY=
MODEL_FAST_API_KEY=
# Optional defaults for the custom channel.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_MODEL=gpt-4.1-mini

# Optional but recommended: encrypts a model API key saved from the UI.
# Keep this value private and stable. Changing it makes the saved key unreadable.
MODEL_CONFIG_ENCRYPTION_KEY=

# Optional Taobao Open Platform OAuth settings.
TAOBAO_APP_KEY=
TAOBAO_APP_SECRET=
TAOBAO_REDIRECT_URI=http://localhost:4317/api/auth/taobao/callback

# Optional but recommended: encrypts locally stored Feishu Webhook and signing secret.
# Keep this value private and stable. Changing it makes existing Feishu credentials unreadable.
FEISHU_CONFIG_KEY=
