@ecomMonitorLatest path /ecom-monitor/latest.json
handle @ecomMonitorLatest {
	root * /srv/ecom-monitor
	rewrite * /latest.json
	header Cache-Control "public, max-age=60, must-revalidate"
	file_server
}

handle_path /ecom-monitor/* {
	root * /srv/ecom-monitor
	header Cache-Control "public, max-age=31536000, immutable"
	file_server
}
